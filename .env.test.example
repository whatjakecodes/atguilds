# Credentials for the Playwright e2e guild-invite flow (e2e/guild-invite-flow.test.ts).
# Copy this file to `.env.test` and fill in two REAL bsky.social test accounts.
#
# Notes:
# - Use canonical handles (e.g. alice.bsky.social) — the invite is matched by handle.
# - Use the account's MAIN password (accounts must NOT have 2FA). App passwords do NOT
#   work — the bsky OAuth sign-in page rejects them — so use a dedicated throwaway test
#   account, never a real personal one.
# - `.env.test` is gitignored; never commit real credentials.

TEST_USER1_HANDLE=alice.bsky.social
TEST_USER1_PASSWORD=main-account-password

TEST_USER2_HANDLE=bob.bsky.social
TEST_USER2_PASSWORD=main-account-password

# PDS / entryway used for the cleanup login. Defaults to https://bsky.social.
PDS_SERVICE=https://bsky.social
