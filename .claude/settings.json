{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(.env.!(example|*.example))",
      "Read(**/.env.!(example|*.example))"
    ],
    "allow": [
      "Read(.env.example)",
      "Read(**/.env.example)",
      "Read(.env.test.example)",
      "Read(**/.env.test.example)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "**/.env",
        "**/.env.*"
      ],
      "allowRead": [
        "**/.env.example",
        "**/.env.test.example"
      ]
    }
  }
}
