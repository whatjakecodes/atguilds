		"svelte": "5.55.6",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.17",
		"tsx": "^4.19.2",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "8.0.5",
		"vitest": "3.0.5",
		"web-vitals": "^3.5.0"
	},
	"dependencies": {
		"@atproto/api": "0.20.15",
		"@atproto/common": "0.6.2",
		"@atproto/identity": "0.5.0",
		"@atproto/lexicon": "0.7.1",
		"@atproto/oauth-client-node": "0.4.1",
		"@atproto/xrpc": "0.8.0",
		"@atproto/xrpc-server": "0.11.1",
		"@neondatabase/serverless": "^0.10.4",
		"@vercel/analytics": "^1.4.1",
